# asp/.env.example — copy to asp/.env and fill. NEVER commit asp/.env.
# The ASP reads ONLY this file, never the bot's root .env. These are fresh,
# ASP-only values. Market-data keys are read-only data keys (not money secrets).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8402
# Public HTTPS URL. PERMANENT on-chain once registered as the A2MCP endpoint.
# Set to the Render URL before you register. Localhost is fine for local dev.
ASP_PUBLIC_URL=https://theia-asp.onrender.com
ASP_NAME=Theia

# ── x402 (seller side) ────────────────────────────────────────────────────────
# Our Agentic Wallet address on X Layer (the x402 payTo). Get it after login with
#   onchainos wallet addresses --format json
X402_PAY_TO=
# `exact` = settle-now (EIP-3009), the simple default.
X402_SCHEME=exact
# Default settlement asset (USDT or USDG).
X402_DEFAULT_ASSET=USDT
# [OPEN] X Layer (196) token contract addresses. Confirm via `onchainos wallet
# chains` or an okx-dex-token lookup before go-live.
X402_ASSET_USDT_ADDRESS=
X402_ASSET_USDT_DECIMALS=6
X402_ASSET_USDG_ADDRESS=
X402_ASSET_USDG_DECIMALS=6
# [OPEN] OKX x402 facilitator base URL for X Layer resource servers. Confirm with
# `onchainos agent x402-check`. Leave blank to use the middleware default.
X402_FACILITATOR_URL=
# Per-call prices in USDT (cheap flat, $0.02 to $0.10).
PRICE_SIGNAL=0.10
PRICE_MANIPULATION=0.05
PRICE_CEX_FLOW=0.05
PRICE_INSIDER=0.05
PRICE_LIQMAP=0.05
PRICE_CEX_HOLDINGS=0.02
# Turn ON only when payTo + asset address + facilitator are all set. Off => free
# (lets you build and demo the engine before live settlement is wired).
X402_ENFORCE=0

# ── OKX identity (filled after registration; informational only) ──────────────
OKX_ASP_AGENT_ID=
OKX_OWNER_EMAIL=

# ── Engine data sources (fresh copies; the engine needs these for real reads) ──
# Coinalyze: multi-TF TA + funding/OI + liquidations. https://coinalyze.net (free tier).
COINALYZE_API_KEY=
COINALYZE_API_KEY_LIQ=
# Moralis: insider/holder discovery from datacenter IPs. https://moralis.io (free tier).
MORALIS_API_KEY=
# Singapore relay for Binance/Bybit data when the host IP is geo-blocked. Optional.
RELAY_BASE_URL=
BYBIT_BASE_URL=
BYBIT_PROXY_SECRET=
# Universe sizing (on-demand ASP is smaller than the bot).
ASP_UNIVERSE_TOP_N=300
ASP_UNIVERSE_VOLUME_TOP_N=200
ASP_ENABLE_BINANCE_FUTURES=1
ASP_ENABLE_TEAM_DISCOVERY=1
ASP_TEAM_MAX_TOKENS=100
ASP_VERBOSE=0

# ── Reputation ledger (publish REAL resolved outcomes to X Layer) ─────────────
REPUTATION_LEDGER_ENABLED=0
REPUTATION_SINK=calldata
REPUTATION_CONTRACT=
# Reads real outcomes from the signal-tracker journal. Defaults to logs/signals.jsonl.
REPUTATION_SIGNALS_PATH=
