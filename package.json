{
  "name": "trade-alert-bot",
  "version": "0.1.0",
  "description": "Telegram alert bot that correlates 1m price surges on CEXes with on-chain CEX hot/cold wallet flows (ETH, BSC, Solana)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node test/sanity.js",
    "test:asp": "node test/asp-sanity.js",
    "test:all": "node test/sanity.js && node test/asp-sanity.js",
    "asp": "node asp/server.js",
    "asp:demo": "node asp/demo/executor.js",
    "derive-weights": "node -r dotenv/config src/tools/derive-weights.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/web3.js": "^1.95.3",
    "candlestick": "^1.2.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.21.2",
    "indicatorts": "^2.2.2",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.21.0",
    "technicalindicators": "^3.1.0",
    "trading-signals": "^7.4.3",
    "undici": "^6.26.0",
    "ws": "^8.18.0",
    "x402-express": "^1.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
