TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=

TELEGRAM_API_PROXY=

COINGECKO_API_KEY=

MIN_FLOW_USD=500000

SURGE_PCT=3

CORRELATION_WINDOW_MIN=15

MIN_SIGNAL_SCORE=3.0

MIN_OBSERVATION_SCORE=1.5

SIGNAL_COOLDOWN_MIN=30

PRICE_POLL_INTERVAL_MS=60000

MIN_24H_VOLUME_USD=500000

SIGNAL_RESOLVE_INTERVAL_MS=300000

GOOGLE_SHEET_URL=https://script.google.com/macros/s/AKfycbydeIo5suskfVScG1nCFu9EOU-MV74GqGakH0YInjJaykKFb-yLIxYVIBfO8e-NuuqhYg/exec

FUNDING_POLL_INTERVAL_MS=1800000

OBSERVE_MIN_FLOW_USD=1000000

FUNDING_LEADERS_MIN=30

FUNDING_INTERVAL_HRS=1

ENABLE_BINANCE_FUTURES=1

COINALYZE_API_KEY=
# OPTIONAL 2nd Coinalyze key dedicated to the LIQUIDATION poll. STRONGLY
# recommended: it gives liquidations their OWN ~40/min budget (no contention
# with TA) and, via the relay, a separate egress IP. Without it, the single key
# is auto-split (liquidations get a reserved slice). Get a free 2nd key at
# coinalyze.net and paste it here.
COINALYZE_API_KEY_LIQ=
# Coinalyze rate gate (calls/min, per key, cap ~40). With a 2nd key this is the
# shared (TA/funding) budget; with one key it's the TOTAL that gets split.
COINALYZE_RATE_LIMIT=35
# Liquidation client rate (calls/min). With a 2nd key, ~35 (its own budget);
# with one key, a reserved slice (default 16) of COINALYZE_RATE_LIMIT.
COINALYZE_LIQ_RATE_LIMIT=35
# Let high-edge triggers (flow/distribution/funding_extreme/liquidation) fire
# even when multi-TF alignment is weak — they're the proven edge + counter-trend
# by nature, and the alignment caps were demoting them to observation-only. =0
# to re-apply the alignment tier caps to them.
HIGH_EDGE_ALIGNMENT_EXEMPT=1

# Liquidation DETECTION significance = what gets a "💥 Liquidation" heads-up alert (per
# BYBIT_LIQ_WINDOW_MIN sliding window): liq/OI >= LIQ_OI_PCT OR liq >= MIN_LIQUIDATION_USD,
# above a $LIQ_MIN_FLOOR_USD dust floor. Tune to taste — strict (200000 / 0.0005 / 75000)
# keeps alerts to top tokens. IMPORTANT: detection ≠ SIGNALS. Whether a liquidation becomes
# a trade signal is the LIQ_MAJOR_BASE_FLOOR logic below, not these.
MIN_LIQUIDATION_USD=50000
LIQ_OI_PCT=0.0001
LIQ_MIN_FLOOR_USD=25000
# Bybit liquidation feed via the Fly Tokyo forwarder's /liquidations buffer — the
# real-time, accurate source (Binance geo-blocks cloud IPs; Coinalyze under-reports
# ~85%). When LIQ_FORWARDER_URL is set, the Coinalyze monitor drops to OI-only (just
# feeds the OI-% significance model) and Bybit emits the liquidations. Unset = Coinalyze.
LIQ_FORWARDER_URL=https://tradealert-liq-fwd.fly.dev
BYBIT_LIQ_POLL_MS=20000
# SLIDING window (minutes) over which Bybit liquidations are summed for the
# significance test. A cascade builds over minutes, so a per-minute reset (the old
# behaviour) lost it; 3 min lets a building cascade accumulate past the floor.
BYBIT_LIQ_WINDOW_MIN=3
# Liquidation → SIGNAL gate (NOT detection). A liquidation is a tradeable squeeze on a
# LIQUID major (BTC/ETH/top perps) and rekt-bait on an illiquid small-cap, so:
#   • LIQUID (OI ≥ LIQ_SIGNAL_MIN_OI_USD or mcap ≥ LIQ_SIGNAL_MIN_MC_USD) → base
#     LIQ_MAJOR_BASE_FLOOR (2.0 = the 56%-WR commit's behaviour), so a $300k+ BTC/ETH
#     squeeze reaches signal grade with ordinary confluence. Lower it to fire fewer.
#   • ILLIQUID → capped at LIQ_ILLIQUID_CAP (0.4): stays a "💥 Liquidation" heads-up,
#     can never carry a trade signal alone. The "don't get me rekt on small-caps" guard.
LIQ_SIGNAL_MIN_OI_USD=30000000
LIQ_SIGNAL_MIN_MC_USD=1000000000
LIQ_MAJOR_BASE_FLOOR=2.0
LIQ_ILLIQUID_CAP=0.4
# A liquidation gets +score scaled by its size relative to OI (+1.0 at ≥1% of OI),
# and a liq ≥ LIQ_VIOLENT_OI_PCT of OI gets +1 signal tier — so a genuinely violent,
# market-moving cascade can reach signal grade (vs a routine wick). 0.005 = 0.5% of OI.
LIQ_VIOLENT_OI_PCT=0.005

LIQUIDATION_POLL_INTERVAL_MS=300000
LIQUIDATION_TOP_N=50
# Binance's !forceOrder WebSocket — DEAD on cloud hosts. Binance geo-blocks the data
# on every cloud IP tried (Render US, Fly Singapore + Tokyo): the socket opens and the
# SUBSCRIBE is acked, but ZERO market data is pushed. Coinalyze (above) is the source.
# Only set =1 if BINANCE_LIQ_WS_URL points at a forwarder on a CLEAN-IP VPS (not Fly/Render).
BINANCE_LIQ_WS=0
# Observability for the WS feed: a heartbeat logs frame + tracked-liquidation
# counts every BINANCE_LIQ_HEARTBEAT_MIN minutes (proves it's alive even when
# nothing crosses the alert threshold). BINANCE_LIQ_DEBUG=1 logs EVERY liquidation
# received (flip on to watch the stream, then off).
BINANCE_LIQ_HEARTBEAT_MIN=10
BINANCE_LIQ_DEBUG=0

FUNDING_TOP_N=250

FUNDING_LEADERS_MIN_OI=10000000

UNIVERSE_TOP_N=500
# Universe is cached in Neon; on restart the CoinGecko rebuild (~19 calls) is SKIPPED
# when the cached copy is younger than this. 24h keeps CoinGecko usage near zero across
# frequent restarts (free-tier churn). Lower for fresher metadata; clear the Neon
# 'universe/cache' doc to force a rebuild.
UNIVERSE_CACHE_TTL_HRS=24

VERBOSE=0

ENABLE_ETH=1
ENABLE_BSC=1
ENABLE_SOL=1

KEY_ENCRYPTION_SECRET=

AUTOTRADE=off

AUTOTRADE_ARMED=0
AUTOTRADE_RISK_PCT=2
AUTOTRADE_MAX_POSITION_USD=50
AUTOTRADE_MAX_CONCURRENT=10
AUTOTRADE_MAX_LEVERAGE=20
AUTOTRADE_DAILY_LOSS_PCT=10
AUTOTRADE_MARGIN_USD=0
AUTOTRADE_PAPER_MARGIN_USD=100
# tp2 (not tp1): signal ideas are ~+0.14R but a tp1 exit caps winners at ~1R while
# losers cost -1R. tp2/trailing capture where the +R lives (20-day Neon pull).
AUTOTRADE_TP_TARGET=tp2
AUTOTRADE_TRAILING=1
# PROFIT-TRAIL: after the +BE_TRIGGER_PCT breakeven move, ratchet the stop to lock
# (favourable% − TRAIL_GAP_PCT) of profit, only ever moving up. A pop to +4% that
# reverses then exits ~+2% instead of scratching at breakeven — the fix for "80%
# of breakevens then go to SL, rarely hit TP". 0 = breakeven-only (old behaviour).
TRAIL_GAP_PCT=2.0
# LIQUIDATION SAFETY: cap leverage so the isolated-liquidation price sits at least
# this fraction BEYOND the SL, so the stop always triggers before liquidation
# (fixes "SL below liquidation price" trades). 0.015 = liq ≥ 1.5% past the stop.
AUTOTRADE_LIQ_BUFFER=0.015
AUTOTRADE_SHORT_ONLY=0
AUTOTRADE_MIN_ALIGNMENT=4
AUTOTRADE_MONITOR_MS=30000
# Signal-quality gates (live-data audit 2026-06-10, 345 resolved signals).
# Momentum buckets lose money on live capital (movers 33.8% WR, surge 41%) vs
# the on-chain/funding edge (flow/funding_extreme/liquidation 60-70%). By
# default the autotrader does NOT deploy capital on momentum triggers; flip to 1
# to re-enable (alerts still fire either way).
AUTOTRADE_ALLOW_SURGE=0
AUTOTRADE_ALLOW_MOVERS=0
# Per-trigger autotrade allowlist (generalised). Every signal SOURCE can be gated
# here: AUTOTRADE_ALLOW_<TRIGGER> = 1 (allow) / 0 (block). Recognised triggers:
# FLOW, LIQUIDATION, FUNDING_EXTREME, LIQSWEEP, VOLUMESPIKE, WATCHLIST, MAJORS,
# SURGE, MOVERS, DISTRIBUTION. Defaults: SURGE/MOVERS/DISTRIBUTION OFF (weak WR),
# everything else ON. LISTING has its own AUTOTRADE_LISTING gate. These run
# ALONGSIDE the TF-alignment / horizon gates (not instead of them), and each user
# can override per-account in /autotrade → Signal filters → Which triggers.
# AUTOTRADE_ALLOW_DISTRIBUTION=1   # uncomment to autotrade distribution signals
# 20-day expectancy pull: FLOW (30% WR, -0.21R) + FUNDING_EXTREME (32% WR, -0.11R)
# lose money as firing triggers → demoted to alert-only. Still count as confluence
# on other signals (this gates the trade, not the score). =1 to re-enable auto-fill.
AUTOTRADE_ALLOW_FLOW=0
AUTOTRADE_ALLOW_FUNDING_EXTREME=0
# Anti-top-chasing: even when a scan/momentum signal is allowed, skip the FILL if
# it enters into a stretched move (entry-TF extreme or >=2 HTF overextended against
# the trade) — the "WCT longed the +20% top" failure. On-chain triggers (flow /
# distribution / liquidation) are exempt. 1 = chase anyway.
AUTOTRADE_CHASE_EXHAUSTED=0
# Auto-trade ONLY the A+ high-conviction subset (multi-edge "fat pitches" — the
# highest-win-rate trades). 1 = capital only on A+; everything else still ALERTS.
# This is the honest path to a high win rate: selectivity, not a magic number.
AUTOTRADE_HIGH_CONVICTION_ONLY=0
# New-listing catalyst (Upbit/Bithumb/Binance) — ~95% pump on the announcement
# before any multi-TF structure exists. When 1, listing signals AUTOTRADE STRAIGHT,
# bypassing the horizon + TF-alignment gates (still MEDIUM+, LONG, valid plan,
# and the risk/daily-loss/sizing gates). Set 0 to make listings signals-only.
AUTOTRADE_LISTING=1
# A new listing fires a tradeable/autotrade signal even at LOW tier — a token listed
# minutes ago has no multi-TF history to reach MEDIUM, which otherwise forced every
# listing to info-only. Still requires a real perp + usable trade plan (so Korean
# spot-only tokens with no Bybit perp stay info-only — can't autotrade what has no market). 0 reverts.
LISTING_SIGNAL_RELAXED=1
# Soft confluence gate: a surge/movers signal only FIRES if it carries a
# predictive on-chain/funding reason (flow, funding_trigger, distribution,
# teamFlow, priorFlows, liquidation, fundingVelocity, supplyPct). Set 0 to fire
# all momentum signals again (the old, noisier behaviour).
# OPT-IN (default OFF): set =1 to require surge/movers signals to carry an
# on-chain/funding reason before firing. Default OFF = baseline (3ee561d) firing
# where momentum fires like any other token.
MOMENTUM_REQUIRE_EDGE=0
# CVD (cumulative volume delta) veto — kills momentum entries the aggressive
# order-flow contradicts ("price up but net selling" = fakeout). OPT-IN: set =1
# to enable (default OFF). Tunables: window bars, min price move % over the
# window, and the net-delta-vs-volume ratio that counts as opposing flow.
CVD_VETO=0
CVD_BARS=15
CVD_MIN_PRICE_MOVE_PCT=0.4
CVD_OPPOSE_RATIO=0.06
# ── Scoring reweight (ranks 4-5). Values below = CURRENT behaviour (no change).
# Set the RECOMMENDED values (comments) to de-fund anti-predictive momentum/TA/OI
# and raise the predictive on-chain/funding edge — but ONLY after ranks 1-3+CVD
# have a couple weeks of data, change them TOGETHER, and re-derive targets with
# `node src/tools/derive-weights.js`. Shipping these unvalidated can starve the
# good triggers, so they default OFF (no change).
SURGE_BASE=1              # recommend 0.5
TA_SOFT_CAP=1.5          # recommend 0.75
TA_HARD_CAP=2.5          # recommend 1.0
OI_FRESH_CREDIT=0.5      # recommend 0
FLOW_BASE_BOOST=0        # recommend 0.5
TEAM_SELL_PTS=0.8        # recommend 1.2
FUNDING_EXTREME_BASE=0   # recommend 1.0 (keep < firing bar)
DISTRIBUTION_BASE=2.5    # best bucket (70% WR); raise cautiously
# Extra bearish weight when supply is deposited INTO an exchange COLD wallet
# (pre-distribution staging — the BEAT/VELVET/SAHARA "into cold storage" tell).
COLD_DEPOSIT_BOOST=0.6
# RSI-overbought (vs LONG) / oversold (vs SHORT) penalty multiplier when the same
# TF is trending WITH the trade (continuation, not exhaustion). 0.4 = 60% lighter;
# 1 = full penalty. Stops strong trend-aligned signals being over-penalised.
RSI_AGAINST_TREND_MULT=0.4
# BUT a blow-off extreme (RSI ≥ RSI_BLOWOFF_OB, or ≤ RSI_BLOWOFF_OS) is NOT
# continuation — the softening is switched OFF there and the full RSI penalty
# applies (VELVET LONG fired into daily RSI 98.9 because softening swallowed it).
# These also drive a single-TF blow-off tier demotion in the conductor's
# exhaustion gate (one lone TF ≥88 against the trade = a top/bottom on its own).
RSI_BLOWOFF_OB=85
RSI_BLOWOFF_OS=15
# RSI DIVERGENCE (regular) — a reversal tell independent of the (anti-predictive)
# momentum stack: price higher-high while RSI lower-high → bearish (supports SHORT);
# price lower-low while RSI higher-low → bullish (supports LONG). Confirmation-only
# (never penalises), HTF-only (1h/4h/daily/1week — noise on 1m/5m). Strongest where
# the bot already fades (exhaustion-reversal / liquidity-grab). Score = the TF's
# finding weight × DIVERGENCE_MULT. RSI_DIVERGENCE=0 disables.
RSI_DIVERGENCE=1
DIVERGENCE_MULT=1.0
# MANIPULATION-RISK score (NOX's low-cap pump-and-dump filters): futures>>spot
# volume, 24h volume ≈/≥ market cap, low circulating float, top-10 holder
# concentration → a 0..1 risk. On risky tokens the conductor DE-WEIGHTS positive TA
# (chart is noise), PENALISES a LONG (don't chase the pump) and BOOSTS a SHORT
# (fade the dump). MANIP_GUARD=0 disables. TA_DEWEIGHT 0.6 = TA keeps 40% at risk=1.
MANIP_GUARD=1
MANIP_TA_DEWEIGHT=0.6
MANIP_LONG_PENALTY=1.2
MANIP_SHORT_BOOST=0.6
# Resolution data-integrity guard (the "BEAT said TP3 hit but never moved" bug).
# SL/TP touches come from exchange 1m klines; a thin perp can print a PHANTOM wick
# that resolves a trade against a move that didn't happen market-wide. Before
# booking a terminal win/loss, the exit is cross-checked against the INDEPENDENT
# CoinGecko price — if they disagree by more than this %, the resolution is marked
# AMBIGUOUS (excluded from win-rate) and logged, instead of a fabricated win/loss.
RESOLVE_DIVERGENCE_PCT=12
# A Break of Structure only counts if price is within this %% of the broken level
# (a RECENT break, not an ancient one price already ran 200% past).
BOS_MAX_DIST_PCT=30
# Structural-location guard (live-audit headline fix). The biggest losing pattern
# is a trend-following MARKET entry filled straight into the opposing structure:
# LONG into resistance / a double-top, SHORT into support / a double-bottom (the
# FHE + TAG screenshots). The confluence says "go" but there's no ROOM before the
# wall, so price taps it, rejects and stops out (losers peak +2.8%, bleed −6.9%).
# This measures the nearest opposing swing level in the trade's path and demotes:
#  • a CLUSTERED shelf (≥2 levels within STRUCT_SHELF_PCT) inside STRUCT_ROOM_PCT,
#    with TP1 beyond it → observation-only (won't fire/autotrade).
#  • a single near level inside STRUCT_ROOM_SINGLE_PCT, TP1 beyond it → −1 tier.
# EXEMPT: liquidity-grab + exhaustion-reversal entries (they target structure on
# purpose) and breakouts (price already past all structure → nothing ahead).
# Set STRUCT_GUARD=0 to disable entirely.
STRUCT_GUARD=1
STRUCT_ROOM_PCT=4.0
STRUCT_ROOM_SINGLE_PCT=2.0
STRUCT_SHELF_PCT=2.0
# Early breakeven (live-audit stop fix). The TP1-gated trailing ratchet never
# fires for trades that peak BELOW TP1 then reverse — the dominant loser shape
# (avg loser peaks +2.8% then bleeds −6.9%; winners dip only −1.5%). Once an open
# trade shows +BE_TRIGGER_PCT in favour, the stop lifts to entry(+BE_OFFSET_PCT
# fee buffer), so a green-then-red trade SCRATCHES instead of taking the full
# stop. Applies to autotrade fills AND the win-rate stats (a scratch resolves as
# BREAKEVEN, excluded from W/L). 0 disables. Mirrored in auto-trader + signal-tracker.
# Raised 1.5→3.0: 20-day pull showed 22% of trades scratch at BREAKEVEN — the early
# arm was locking entry on routine +1.5% noise before the move developed, eating
# winners. 3.0 gives room to breathe; lower for tighter protection, 0 to disable.
BE_TRIGGER_PCT=3.0
BE_OFFSET_PCT=0.1
# Volatility-scale the breakeven arm + profit-trail gap to the trade's SL distance,
# so a high-ATR token (e.g. 7% SL) gets room (BE ~+2.5%, trail ~2.1%) instead of
# scratching inside its noise band, while calm tokens keep the tight flat floors.
# effective = max(flat floor above, frac × SL%). 0 = pure flat (old behaviour).
BE_SL_FRAC=0.35
TRAIL_SL_FRAC=0.30
# R:R floor for AUTOTRADE fills: skip a trade whose exit target (tp3 when trailing,
# else the configured TP) pays less than the stop risks (VELVET's TP1 was 0.81R).
# Signals still ALERT; this only blocks deploying capital on sub-1R setups. 0 = off.
AUTOTRADE_MIN_RR=1.0
# SL/TP trigger price source on Bybit: MarkPrice (default, smoothed index — avoids a
# single-venue last-trade wick stopping you out), LastPrice, or IndexPrice.
AUTOTRADE_SLTP_TRIGGER=MarkPrice
# SL ceiling per horizon (%). The stop is anchored just beyond a protective swing
# but capped here so a wide-ATR token can't ship a ruinous stop. Tightened from
# the old 4/6/9/12 (SWING 8% WR + DAY 0% were the wide-stop bleeders; winners only
# dip −1.5%). On a maxPositionUsd-capped account the notional is fixed, so a
# tighter stop = a smaller $ loss. Tension: too tight gets wicked out (WAL),
# too wide bleeds (MYX) — raise these if you see premature stop-outs.
SL_MAX_PCT_SCALP=4
SL_MAX_PCT_DAY=5
SL_MAX_PCT_SWING=7
SL_MAX_PCT_POSITION=9
# Liquidation heatmap (/liqmap + conductor magnets). 4h candles over 120 days =
# 4× finer than daily; ±80% range drops far phantom clusters. Closer to Coinglass.
LIQMAP_INTERVAL=4hour
LIQMAP_DAYS=120
LIQMAP_MAX_DIST_PCT=80
# Fire-time on-demand compute: the conductor now computes the leverage heatmap for
# EVERY firing candidate (not just pre-warmed hot-movers) so the liqLevels magnet
# counts on every signal. Cache-first; a cold compute races this timeout (ms) so a
# signal is never materially delayed. A timed-out compute still finishes in the
# background and warms the cache for the next fire. Runs on the dedicated liq key.
LIQMAP_FIRE_TIMEOUT_MS=2500
# Adaptive leverage distribution for the heatmap. A fixed 5/10/25/50/100x fan
# makes every token's liq ladder the same shape and paints a phantom 100x@±1%
# band on coins that swing 8%/bar. With this ON, the leverage weights are derived
# from the token's realized volatility (peak comfortable leverage ≈ LIQMAP_LEV_K /
# per-bar-range%), so high-vol memes skew to low leverage / wider bands and stable
# majors keep more high-lev. 0 = revert to the fixed brackets.
LIQMAP_ADAPTIVE_LEV=0
LIQMAP_LEV_K=50
PAPER_BALANCE_USD=1000

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=0

BYBIT_BASE_URL=
BYBIT_PROXY_SECRET=
BYBIT_PROXY=

TELEGRAM_COMMANDS=1
PRICE_CG_EVERY_N=15
UNIVERSE_VOLUME_TOP_N=300
# ── Coverage plumbing (all OPT-IN, default off) ────────────────────────────
# UNIVERSE_HOT_REFRESH_MS — periodically re-fetch the top-by-volume set and merge
#   tokens that surged into heavy trading after boot (a fresh listing / parabolic
#   name) so they get TA/funding/on-chain coverage without a full rebuild. 0 = off.
# PERP_MAP_REFRESH_MS — periodically rebuild the Coinalyze perp map so newly-FAVORED
#   (hot-mover) tokens pick up funding/liq/TA perp coverage. Additive. 0 = off.
# ONCHAIN_RESOLVE_PER_MIN — when a tracked CEX/team wallet moves an UNTRACKED token,
#   resolve it via CoinGecko's contract endpoint (this many attempts/min) so the flow
#   is covered. 0 = off. Misses neg-cached ONCHAIN_RESOLVE_NEG_HRS. NOTE: on-chain flow
#   is currently the anti-edge — leave at 0 until flow selection is fixed.
# UNIVERSE_HOT_REFRESH_MS=900000
# PERP_MAP_REFRESH_MS=1800000
ONCHAIN_RESOLVE_PER_MIN=0
ONCHAIN_RESOLVE_NEG_HRS=6
# Per-CEX holdings leaderboard (the 🏦 CEX holdings menu — pick an exchange, see the
# tokens it holds the most of by % of circulating supply). Multicall3-batched so a
# refresh is ~a dozen RPC calls, not thousands; result cached in Neon (menu reads
# cache, zero RPC on click). CEX_HOLDINGS_REFRESH_MS=0 disables the refresh (menu
# shows cached/empty); 3600000 = hourly. CEX_HOLDINGS_TOKEN_SET = how many top-mcap
# tokens to scan (pinned + hot movers always included → cornered microcaps caught).
CEX_HOLDINGS_REFRESH_MS=3600000
CEX_HOLDINGS_TOKEN_SET=300
# ── Optional LLM layer (any OpenAI-compatible provider) ────────────────────────
# LANGUAGE tasks only — reasoning over the bot's own deterministic facts. NEVER touches
# trade scoring, sizing or firing; that stays deterministic + auditable. Fail-soft
# everywhere. Provider-agnostic via HYPERBOLIC_BASE_URL. USE A FAST ONE: Groq is free
# and ~1s (Hyperbolic's free tier tested 30-80s+, unusable for interactive /brief).
#   Groq:       BASE_URL=https://api.groq.com/openai/v1   MODEL=llama-3.3-70b-versatile
#   Hyperbolic: BASE_URL=https://api.hyperbolic.xyz/v1    MODEL=deepseek-ai/DeepSeek-V3-0324 (slow)
# LLM_BRIEF=1 turns the /brief command's AI narration on (default 0 = instant template).
HYPERBOLIC_API_KEY=
HYPERBOLIC_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_MS=15000
LLM_BRIEF=0
# Pinned/favored tokens fire at a modestly lower bar than MIN_SIGNAL_SCORE: your
# own curation is the edge. Keep it BELOW MIN_SIGNAL_SCORE or the discount is dead
# and the watchlist scan can't surface forming setups early.
MIN_SIGNAL_SCORE_PINNED=2.5
MOVERS_SCAN_MIN=30
MOVERS_TOP_N=10
# Top-MC majors scan — proactively run the full confluence engine over the liquid
# majors (top by market cap, where TA is reliable vs manipulated low-caps) every
# MAJORS_SCAN_MIN minutes, at NORMAL thresholds (only genuine score fires). Rotates
# MAJORS_TOP_N per scan through the top MAJORS_DEPTH to bound API cost. 0 disables.
MAJORS_SCAN_MIN=60
MAJORS_TOP_N=20
MAJORS_DEPTH=60
# Proactive WATCHLIST scan: run the full confluence engine over every pinned token
# every N min so a forming setup (structure + flow + funding) fires EARLY at the
# pinned bar, instead of waiting for a reactive surge that lands at the blow-off top
# (the WCT case). Paced ~0.8s/token. 0 disables.
WATCHLIST_SCAN_MIN=15
LISTING_MONITOR=1
# How often to poll for new listings. This IS your detection lag — at 120000 (2min) a
# listing can be up to 2 min stale. Drop to 20000-30000 to catch listings within ~20s
# (the Upbit/Bithumb proxies handle the extra polls fine). The single biggest lever for
# "get listing alerts as fast as possible".
LISTING_POLL_INTERVAL_MS=30000
# A brand-new listing's Bybit/Coinalyze perp registers seconds-to-a-minute AFTER the
# announcement, so the first perp lookup finds nothing → no TA → no auto-trade (the ARX
# case). Retry the (cache-bypassing) perp lookup this many times, this many seconds
# apart, before evaluating, so the listing actually auto-trades once the perp is live.
LISTING_PERP_RETRIES=6
LISTING_PERP_RETRY_SEC=15
# A genuine listing surfaces within minutes; anything older that the de-dup missed (a
# stale proxy page / lost seen-set / edited re-publish) is a re-surfaced OLD post and is
# vetoed by age — the backstop against "N old listings fired at once" spam.
LISTING_MAX_AGE_HRS=12
# On restart/downtime the on-chain monitor's lastBlock lags the head; scanning that
# backlog replays OLD transfers stamped with detection time (a 2pm flow alerting at 9pm).
# Only ever scan the most recent N minutes of blocks; skip the stale backlog.
ONCHAIN_MAX_CATCHUP_MIN=15
# Upbit announcements 403 from US + Singapore IPs (Cloudflare); a Fly TOKYO forwarder
# clears it. Point this at the forwarder's /upbit route. Empty = relay/direct (will 403).
UPBIT_PROXY_URL=https://tradealert-liq-fwd.fly.dev/upbit

# ── Token-unlock alerts (vesting-cliff heads-up via DeFiLlama, free/keyless) ──
# Warns a week + a day before a "major" cliff unlock (incoming supply → sell
# pressure). Set UNLOCK_MONITOR=0 to disable. "Major" = ≥5% of circulating supply
# OR ≥$25M by default. UNLOCK_PROTOCOLS controls coverage:
#   • unset            → a curated ~28 high-vesting majors (lighter).
#   • all              → EVERY token DeFiLlama tracks (~336), incl. mid/low-caps
#                        like resolv, humanity, drift, walrus. RECOMMENDED for the
#                        broadest coverage (note: CoinGecko has no unlock data, and
#                        DeFiLlama doesn't track every micro-cap, e.g. HOME).
#   • a,b,c            → a custom comma-separated DeFiLlama-slug list.
UNLOCK_MONITOR=1
UNLOCK_MIN_PCT=0.05
UNLOCK_MIN_USD=25000000
UNLOCK_PROTOCOLS=all
UNLOCK_REFRESH_MS=43200000
UNLOCK_POLL_MS=1800000

# ── Macro / Fed-news alerts (FOMC rate decisions + CPI prints) ──────────────
# Calendar-driven (config/macro-calendar.json) — warns 1 day + 1 hour out, then
# "live now" at release. Set MACRO_MONITOR=0 to disable. MACRO_CALENDAR_URL can
# point at a remote JSON (same shape) to update the calendar without a redeploy.
# FRED_API_KEY (free from fred.stlouisfed.org) enables live Fed-funds rate values
# in FOMC alerts; optional — alerts work without it.
MACRO_MONITOR=1
MACRO_POLL_MS=300000
# MACRO_CALENDAR_URL=
# FRED_API_KEY=

# ── Crypto news (free RSS — no key, no quota) ──────────────────────────────
# /news (a menu button under 📋 Menu) shows the latest headlines on demand and
# always works. Source = publisher RSS feeds (CoinDesk + Cointelegraph + Decrypt
# by default), merged newest-first. No API key, no monthly call cap. PUSH alerts
# for HIGH-IMPACT items (hacks, regulation, ETF, listings, macro) are OPT-IN via
# NEWS_MONITOR_PUSH=1. NEWS_MONITOR=0 disables the feed entirely (incl. /news).
# NEWS_FEEDS optionally overrides the default feeds (comma-separated RSS URLs).
# (Was the CryptoCompare JSON API; it moved to a 100-call/month free tier, so this
#  switched to RSS. CRYPTOCOMPARE_API_KEY / NEWS_CATEGORIES are no longer used.)
NEWS_MONITOR=1
NEWS_MONITOR_PUSH=0
NEWS_POLL_MS=300000
NEWS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed

LIQUIDITY_CLUSTERS=1
WALLET_LABEL_AUTORESOLVE=1
TEAM_WALLET_TRACKING=1
TEAM_WALLET_MAX_TOKENS=50
# Insider/team-wallet holder selection. Track ANY holder with ≥ TEAM_MIN_HOLDER_PCT
# of supply (the ">0.5% holder" spec), largest first, up to TEAM_MAX_HOLDERS per
# token; ignore > TEAM_MAX_HOLDER_PCT (contracts/burn/staking). =0 reverts to pure
# top-N rank. Discovery scope = pinned watchlist + current hot-movers (auto-added).
TEAM_MIN_HOLDER_PCT=0.5
TEAM_MAX_HOLDERS=25
TEAM_MAX_HOLDER_PCT=50
# Accumulation detection — the bullish MIRROR of insider distribution. Discovery
# re-snapshots each tracked token's holders on a clock; when a (non-infra, non-CEX)
# wallet's share of supply jumps ≥ ACCUM_MIN_DELTA_PCT between two snapshots taken
# ACCUM_MIN_WINDOW_HRS..ACCUM_WINDOW_DAYS apart, it fires a 🟢 Accumulation alert
# (own notify category, defaults ON). Hot-movers re-snapshot every
# TEAM_HOT_REFRESH_HOURS (cold tokens stay weekly); the whole discovery pass
# re-runs every TEAM_REDISCOVER_HOURS so new hot tokens get picked up without a restart.
ACCUM_MIN_DELTA_PCT=2.0
ACCUM_WINDOW_DAYS=14
ACCUM_MIN_WINDOW_HRS=2
# A holder appearing "from zero" already holding > this % of supply is a
# pre-existing whale newly ENTERING tracking (e.g. after a threshold change), not
# accumulation — suppressed to avoid 0%→34% false alarms. Real gradual buys land lower.
ACCUM_MAX_NEW_PCT=10
TEAM_HOT_REFRESH_HOURS=6
TEAM_REDISCOVER_HOURS=6
MORALIS_API_KEY=
TEAM_FILTER_MAX_ADDR=80

ENABLE_REGIME=1
REGIME_PENALTY=1.0
REGIME_POLL_INTERVAL_MS=300000
REGIME_HIGH_VOL_PCT=1.2

# Top-fade SHORTs measured 22% WR (fades strength while bypassing the alignment cap,
# structural guard, and confirm veto). OFF by default; set to 1 to re-enable.
ENABLE_EXHAUSTION_REVERSAL=0
ENABLE_EXHAUSTION_REVERSAL_LONG=1

DIST_WINDOW_MIN=120
DIST_MIN_USD=500000
DIST_MIN_VOL_PCT=4
DIST_MIN_TRANSFERS=5
DIST_COOLDOWN_MIN=120

COINALYZE_RELAY=0

DATABASE_URL=

# ── Subscription / billing (self-contained in /billing — OFF by default) ──
# Master flag. 1 = run the deposit watcher + /subscribe + trial tracking.
BILLING_ENABLED=0
# 1 = actually BLOCK expired users from premium features. Leave 0 to track-only
# (so enabling billing can never lock anyone out until you are ready).
BILLING_ENFORCE=0
BILLING_PRICE_USD=30
BILLING_TRIAL_DAYS=7
BILLING_MONTH_DAYS=30
# A BRAND-NEW dedicated BIP-39 mnemonic — NEVER reuse one tied to other funds.
# Derives every user deposit address (index 1+) AND the gas wallet (index 0).
BILLING_SEED=
# External address that swept USDT lands in (its key is NOT on the server — safer).
BILLING_HOT_WALLET=
# Chains the sweeper auto-consolidates (BSC/Base gas is ~1c; ETH left for manual/batch).
BILLING_SWEEP_CHAINS=bsc,base
BILLING_POLL_MS=90000

# Flow + distribution FDV ceiling: a CEX hot-wallet outflow only signals on small,
# manipulable tokens. Skip flow/distribution on tokens with FDV >= this (AAVE/PAXG/
# ASTER-class majors = exchange ops, not insider distribution). FDV-unknown falls through.
FLOW_MAX_FDV_USD=500000000

# Insider-SELL materiality: a team sell must be ≥ max($50k, this% × market cap) to
# count as distribution. A $75k sell on $1.2B ENA (0.006% of mcap) is noise; the
# same $75k on a $20M cap is a real dump. Below the floor → demoted to ordinary
# flow (FDV-gated for majors). Kills the mega-cap fake VERY-HIGH shorts.
TEAM_FLOW_MIN_MCAP_PCT=0.0003

# Liquidation base reaches the full +2.0 at this fraction of OI; below it the base
# tapers toward +0.5 so a trivial-%-of-OI liq (e.g. $309k on BTC's huge OI) can't
# carry a signal on its own. A real cascade (big % of a small-cap's OI) keeps full weight.
LIQ_BASE_FULL_OI=0.003

# Cumulative-cascade base: same-side liquidations on a symbol within LIQ_CASCADE_WINDOW_MIN
# are summed; the liquidation base hits full +2.0 at LIQ_CASCADE_FULL_USD cumulative. Lets a
# genuine major-coin cascade ($Ms stacking in minutes, tiny % of OI) fire, which the
# %-of-OI base alone misses (the BTC/ETH cascade case). Scored as max(%OI base, cascade base).
LIQ_CASCADE_WINDOW_MIN=5
LIQ_CASCADE_FULL_USD=2000000

# Fused manipulation/pump-in-progress detector. When this many manipulation legs
# stack on one token (low float + futures>spot + vol>mcap + concentration +
# supply→CEX + liquidation squeeze), it's treated as a coordinated pump → a
# co-occurrence conviction bonus (capped), SHORT-favoring (fade the move). Set
# PUMP_REGIME_MAX_BONUS=0 to disable.
PUMP_REGIME_MIN_LEGS=3
PUMP_REGIME_MAX_BONUS=1.0
# RIDE the squeeze (opt-in, default OFF). When 1, a CONFIRMED squeeze setup
# (negative funding + short-liq fuel above + no distribution) flips the auto-trade
# direction to LONG (ride into the fuel) instead of fading. Powerful but it
# market-buys into a manipulated pump if mistimed: that flip was a big driver of
# the 56%→35% win-rate drop, so it's OFF by default (manipulation always fades).
# The ride read still shows in the alert for MANUAL discretion either way.
PUMP_REGIME_RIDE=0
# Pre-pump SETUP (bullish, EARLY) — the accumulation forming BEFORE a spike: supply
# pulled off a CEX (float tightening) + thin float + OI stacking + volume spike +
# crowded shorts. A capped, LONG-only, confluence-only nudge (can't fire a signal
# alone; never touches a SHORT). OPT-IN (=== '1') so the win-rate A/B stays clean.
ENABLE_PREPUMP=0
PREPUMP_MIN_LEGS=2
PREPUMP_MAX_PTS=1.0
# Futures VOLUME-SPIKE trigger (the "futures volume +1300%" scam-pump tell). Fires a
# both-sides eval when a token's perp 24h turnover jumps ≥ VOL_SPIKE_MULT × its slow-EMA
# baseline, above VOL_SPIKE_MIN_USD. Direction = funding/manip/L-S confluence, not the
# spike. Per-token cooldown; ALPHA = baseline EMA speed (small = slow, won't absorb the
# spike). OPT-IN heuristic. Reuses the cached Bybit perp turnover (no extra API call).
ENABLE_VOLUME_SPIKE=0
VOL_SPIKE_MULT=3
VOL_SPIKE_MIN_USD=5000000
VOL_SPIKE_COOLDOWN_MIN=60
VOL_SPIKE_BASELINE_ALPHA=0.02

# Counter-trend entry on a LIVE move (opt-in, default OFF). When 0 (default), a
# counter-trend trade ALWAYS waits for its limit; if price never pulls back to it,
# there is simply NO TRADE. When 1, a live move (liquidation cascade or aligned
# surge) enters at market instead, which chases (the WCT +20% top-long that hit
# SL). Leave OFF: a missed trade is 0, a chase is a loss.
MOMENTUM_CMP_ENTRY=0

# Liquidation-heatmap magnet: min cluster notional to count as a scoring bump AND
# as a counter-trend entry target; LIQ_MAGNET_MAX_PTS = max score from a magnet.
LIQ_MAGNET_MIN_USD=1000000
LIQ_MAGNET_MAX_PTS=0.9
# Liquidation-map RECENCY half-life (window-fractions). Old OI builds are likely
# already closed/rolled, so their liq levels are less live; weight each build by
# 2^(-age/halfLife) so recent positioning dominates (Coinglass-style). 1.0 = gentle
# (oldest build ~0.5×), smaller = sharper recency, 0 = off (all builds equal).
LIQMAP_RECENCY_HL=1
# Multi-market OI aggregation. The liquidation heatmap SUMS open interest across the
# token's perp markets on every exchange Coinalyze covers (Binance + Bybit + OKX + …)
# instead of one first-listed venue, so magnet zones reflect TOTAL leverage. Price
# candles + L/S stay on the primary market. Costs +1 Coinalyze unit per extra market.
# LIQMAP_AGG_MARKETS=0 disables (single venue); LIQMAP_AGG_MAX caps how many venues.
LIQMAP_AGG_MARKETS=1
LIQMAP_AGG_MAX=3

# Liquidity-SWEEP reversal ("take liquidity both sides"): after price sweeps a
# sizable liq cluster on one side (tags it, the cluster is gone from the next
# snapshot), it tends to reverse and hunt the cluster on the OTHER side. A fresh
# sweep that favours a trade's FADE direction (highs swept → SHORT, lows swept →
# LONG) adds a bounded, size-scaled bonus and names the opposite cluster as the
# target. Confluence-only (capped at LIQ_SWEEP_MAX_PTS, never fires alone). The
# movers warm-cycle also re-evaluates a just-swept token as a reversal candidate.
# LIQ_SWEEP_DETECT=0 disables. MIN_USD = cluster size that counts as swept; MAX_AGE
# = how long a sweep stays actionable.
LIQ_SWEEP_DETECT=1
LIQ_SWEEP_MAX_PTS=0.8
LIQ_SWEEP_MIN_USD=1000000
LIQ_SWEEP_MAX_AGE_MIN=30
# Cascade TPs — on liquidation / liq-sweep trades, extend TP3 from the structural
# target out to the FAR liquidation-cluster magnet (where a cascade would stop), so
# the runner captures the full move price is being pulled toward. Only applies when
# a qualifying magnet sits within CASCADE_TP_MAX_PCT of entry and beyond the normal
# TP3. CASCADE_TP_EXTEND=0 disables; CASCADE_TP_MAX_PCT caps how far out to reach.
CASCADE_TP_EXTEND=1
CASCADE_TP_MAX_PCT=25
