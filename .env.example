# Copy to .env and fill. NEVER commit .env.
# "Onchain OS agent" below = an AI agent (Claude Code / Codex) with the
# okx/onchainos-skills installed. These are not shell commands; you ask the agent.

# ── Server ──
PORT=8402
# Public HTTPS URL. Permanent on-chain once registered as the A2MCP endpoint.
ASP_PUBLIC_URL=https://theia-asp.onrender.com
ASP_NAME=Theia

# ── x402 (seller side) ──
# Your Agentic Wallet address on X Layer (the payTo). Ask your Onchain OS agent for
# your wallet address after logging in.
X402_PAY_TO=
X402_SCHEME=exact
X402_DEFAULT_ASSET=USDT
# [OPEN] X Layer (196) USDT contract address. Ask your Onchain OS agent for the
# X Layer USDT token address.
X402_ASSET_USDT_ADDRESS=
X402_ASSET_USDT_DECIMALS=6
# EIP-712 domain of the settlement token, used to sign the x402 (EIP-3009) payment.
# Must match the on-chain contract exactly or the facilitator returns param_mismatch.
# X Layer 0x779ded... is Tether USD0, on-chain name "USD₮0" (leave unset to use the
# baked-in default; do NOT override with "USDT").
# X402_ASSET_USDT_EIP712_NAME=USD₮0
X402_ASSET_USDT_EIP712_VERSION=1
# OKX facilitator base URL for seller-side verify/settle on X Layer. The middleware
# appends /verify and /settle. OKX endpoint: https://web3.okx.com/api/v6/pay/x402
X402_FACILITATOR_URL=
# OKX API credentials for the facilitator (OK-ACCESS auth). Create at the OKX
# developer portal. Without these the /verify + /settle calls return 401.
X402_FACILITATOR_API_KEY=
X402_FACILITATOR_API_SECRET=
X402_FACILITATOR_API_PASSPHRASE=
# Project ID (some web3.okx.com endpoints require the OK-ACCESS-PROJECT header).
X402_FACILITATOR_PROJECT_ID=
# Per-call prices in USDT.
PRICE_SIGNAL=0.10
PRICE_MANIPULATION=0.05
PRICE_CEX_FLOW=0.05
PRICE_INSIDER=0.05
PRICE_LIQMAP=0.05
PRICE_CEX_HOLDINGS=0.02
# 1 only when payTo + asset + facilitator are set; 0 serves free (dev/demo).
X402_ENFORCE=0

# ── Market data (OKX v5) ──
# 0 disables OKX market data (use only if okx.com is blocked and you have no relay).
ASP_ENABLE_OKX_MARKET_DATA=1
# Blank = direct www.okx.com. Leave blank when RELAY_BASE_URL is set (OKX auto-routes
# via ${RELAY_BASE_URL}/okx). Only set to pin a non-relay OKX base.
OKX_BASE_URL=
# Singapore relay that makes OKX reachable from geo-blocked hosts. Deploy the Fly.io
# relay in relay/ and set its URL + secret here. See relay/README.md.
RELAY_BASE_URL=
RELAY_AUTH_SECRET=
# CoinGecko demo key (free): token universe + spot prices. https://coingecko.com/en/api
COINGECKO_API_KEY=
# Coinalyze: neutral liquidations + TA cache fallback. https://coinalyze.net (free tier).
COINALYZE_API_KEY=
# Optional second Coinalyze key dedicated to liquidations.
COINALYZE_API_KEY_LIQ=
# Moralis: insider/holder discovery. https://moralis.io (free tier).
MORALIS_API_KEY=
# Universe sizing + subsystem toggles.
ASP_UNIVERSE_TOP_N=300
ASP_UNIVERSE_VOLUME_TOP_N=200
ASP_ENABLE_TEAM_DISCOVERY=1
ASP_TEAM_MAX_TOKENS=100
ASP_VERBOSE=0

# ── Reputation ledger (publish REAL resolved outcomes to X Layer) ──
REPUTATION_LEDGER_ENABLED=0
REPUTATION_SINK=calldata
REPUTATION_CONTRACT=
# Real outcomes journal. Defaults to logs/signals.jsonl.
REPUTATION_SIGNALS_PATH=
# X Layer RPC for anchoring the reputation Merkle root (gas-free via the paymaster).
X_LAYER_RPC_URL=https://rpc.xlayer.tech
