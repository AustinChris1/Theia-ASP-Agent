# Copy to asp/.env and fill. The ASP reads ONLY this file, never the bot's root .env.
# NEVER commit asp/.env.

# ── Server ──
PORT=8402
# Public HTTPS URL. Permanent on-chain once registered as the A2MCP endpoint.
ASP_PUBLIC_URL=https://theia-asp.onrender.com
ASP_NAME=Theia

# ── x402 (seller side) ──
# Agentic Wallet address on X Layer (the payTo). From: onchainos wallet addresses --format json
X402_PAY_TO=
X402_SCHEME=exact
X402_DEFAULT_ASSET=USDT
# [OPEN] X Layer (196) USDT contract. Confirm via: onchainos wallet chains
X402_ASSET_USDT_ADDRESS=
X402_ASSET_USDT_DECIMALS=6
# [OPEN] OKX facilitator base URL. Confirm via: onchainos agent x402-check
X402_FACILITATOR_URL=
# Per-call prices in USDT.
PRICE_SIGNAL=0.10
PRICE_MANIPULATION=0.05
PRICE_CEX_FLOW=0.05
PRICE_INSIDER=0.05
PRICE_LIQMAP=0.05
PRICE_CEX_HOLDINGS=0.02
# 1 only when payTo + asset + facilitator are set; 0 serves free (dev/demo).
X402_ENFORCE=0

# ── Engine data sources (the engine's market-data keys; can be their own accounts) ──
# OKX v5 market data (candles/funding/OI). Blank = direct www.okx.com. If okx.com is
# geo-blocked from your host, set this to the relay base (the Worker routes /okx/*).
# Set ASP_ENABLE_OKX_MARKET_DATA=0 when OKX market-data URLs are blocked from your IP.
ASP_ENABLE_OKX_MARKET_DATA=1
OKX_BASE_URL=
# CoinGecko demo key (free): raises the price/universe rate limit to 30/min. Without
# it the keyless tier throttles and prices fail. https://coingecko.com/en/api
COINGECKO_API_KEY=
# Coinalyze: TA + funding/OI + liquidations. https://coinalyze.net (free tier).
COINALYZE_API_KEY=
# Optional second Coinalyze key dedicated to liquidations.
COINALYZE_API_KEY_LIQ=
# Moralis: insider/holder discovery. https://moralis.io (free tier).
MORALIS_API_KEY=
# Singapore relay that makes OKX reachable from geo-blocked hosts. Deploy the Fly.io
# relay in relay/ and set its URL + secret here. See relay/README.md.
RELAY_BASE_URL=
RELAY_AUTH_SECRET=
# Universe sizing + subsystem toggles.
ASP_UNIVERSE_TOP_N=300
ASP_UNIVERSE_VOLUME_TOP_N=200
ASP_ENABLE_TEAM_DISCOVERY=1
ASP_TEAM_MAX_TOKENS=100
ASP_VERBOSE=0

# ── Reputation ledger (publish REAL resolved outcomes to X Layer) ──
REPUTATION_LEDGER_ENABLED=0
REPUTATION_SINK=calldata
REPUTATION_CONTRACT=
# Real outcomes journal. Defaults to logs/signals.jsonl.
REPUTATION_SIGNALS_PATH=
